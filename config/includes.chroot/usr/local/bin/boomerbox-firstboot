#!/bin/bash
# BoomerBox first-boot setup. Idempotent.
# Theme is pre-installed system-wide and applied via /etc/skel xfconf XML.
# This script only handles the deferred Steam install + a defensive theme reapply.
set -u

MARKER="$HOME/.boomerbox-firstboot-done"
LOG="$HOME/.boomerbox-firstboot.log"
[ -f "$MARKER" ] && exit 0

{
  echo "=== BoomerBox first-boot $(date -Iseconds) ==="

  # Defensive theme apply, in case xfconf XML defaults didn't take this session.
  xfconf-query -c xsettings -p /Net/ThemeName       -s "Chicago95"        --create -t string || true
  xfconf-query -c xsettings -p /Net/IconThemeName   -s "Chicago95"        --create -t string || true
  xfconf-query -c xsettings -p /Gtk/CursorThemeName -s "Chicago95-cursor" --create -t string || true
  xfconf-query -c xfwm4     -p /general/theme       -s "Chicago95"        --create -t string || true
  xfce4-panel --restart >/dev/null 2>&1 || true

  # Trust pre-baked desktop shortcuts so XFCE doesn't show "Untrusted launcher".
  for f in "$HOME/Desktop"/*.desktop; do
    [ -f "$f" ] || continue
    chmod +x "$f" || true
    gio set "$f" metadata::xfce-exe-checksum \
      "$(sha256sum "$f" | awk '{print $1}')" 2>/dev/null || true
  done
} >>"$LOG" 2>&1

# Steam install (deferred from ISO build due to i386 multiarch timing).
if ! command -v steam >/dev/null 2>&1; then
  notify-send "BoomerBox" "Installing Steam in the background..." 2>/dev/null || true
  (
    set -x
    sudo dpkg --add-architecture i386
    sudo apt-get update
    if sudo DEBIAN_FRONTEND=noninteractive apt-get install -y steam-installer; then
      notify-send "BoomerBox" "Steam installed. Find it in the Start menu." 2>/dev/null || true
    else
      notify-send "BoomerBox" "Steam install failed. See $LOG" 2>/dev/null || true
    fi
  ) >>"$LOG" 2>&1 &
fi

touch "$MARKER"
notify-send "BoomerBox" "Welcome aboard! Setup complete." 2>/dev/null || true
echo "=== firstboot done $(date -Iseconds) ===" >>"$LOG"
